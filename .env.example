# Copie para .env e ajuste (năo commitar .env).
# Compartilhado entre Flask (app.py) e scripts em Python/ quando exportadas no shell.

FLASK_SECRET_KEY=altere-em-producao

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=consorcio_gm

# Opcional no Flask apenas (alias de DB_*):
# MYSQL_HOST=
# MYSQL_PORT=
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# API de discador (B2) — nao commitar credenciais reais
DISCADOR_URL=https://jbescritorio.b2tecnologia.com.br/suite/api/discar_numero
DISCADOR_USUARIO=
DISCADOR_TOKEN=

# Opcional: TXT SERASA-CONVEM (Python/serasa_conv_txt.py e download em Negativacao).

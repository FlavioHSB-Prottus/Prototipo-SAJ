# Copie para .env e ajuste (năo commitar .env).
# Compartilhado entre Flask (app.py) e scripts em Python/ quando exportadas no shell.

FLASK_SECRET_KEY=altere-em-producao

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=consorcio_gm

# Tempo maximo (segundos) sem actividade efectiva no servidor antes de encerrar a sessao (defeito 3600 = 1h).
# SESSION_IDLE_MAX_SEC=3600

# Opcional no Flask apenas (alias de DB_*):
# MYSQL_HOST=
# MYSQL_PORT=
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# API de discador (B2) ? nao commitar credenciais reais
DISCADOR_URL=https://jbescritorio.b2tecnologia.com.br/suite/api/discar_numero
DISCADOR_USUARIO=
DISCADOR_TOKEN=

# Opcional: TXT SERASA-CONVEM (`Python/serasa_conv_txt.py`). Por defeito usa `Python/serasa_templates/`.
# SERASA_CONV_TEMPLATE_DIR=
# SERASA_CONV_IDENT_INCLUSAO=
# SERASA_CONV_IDENT_EXCLUSAO=
# SERASA_CONV_CX_DETALHE=
# SERASA_CONV_MEIO_ZEROS40=
# SERASA_CONV_CODIGO_CREDOR=

# Remetente exibido na integracao EnviarEmailHtml (MessageCenter); apikey e a mesma do SMS no app.
# EMAIL_MC_REMETENTE=atendimento@joaobarbosa.com.br

# SMTP Google Workspace — apenas no lote de e-mail da pagina Importacao (SMS/e-mail automaticos).
# Implementacao: Python/google_workspace_smtp.py (carregado por app.py no arranque).
# Cobranca e demais envios continuam no MessageCenter. Se nao definido, Importacao tambem usa MC.
# GOOGLE_SMTP_HOST=smtp.gmail.com
# GOOGLE_SMTP_PORT=587
# GOOGLE_SMTP_USER=
# GOOGLE_SMTP_PASSWORD=
# GOOGLE_SMTP_FROM=
